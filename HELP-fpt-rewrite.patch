+function pickPrice(prices) {
+  if (!prices.length) return '';
+  const nums = prices.map((v) => Number(String(v).replace(/\./g, '')));
+  const max = Math.max(...nums);
+  if (max >= 10000000) return prices[nums.indexOf(max)];
+  const recent = [...prices].reverse();
+  const valid = recent.find((v) => Number(String(v).replace(/\./g, '')) >= 10000000);
+  return valid || prices[prices.length - 1];
+}
