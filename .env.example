PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1
NODE_ENV=development
LOG_LEVEL=info
SCRAPE_DEALERS=MBW,CPS,FPT
OUTPUT_JSON=false

# Google Service Account JSON (full JSON string, single line, base64 or raw escaped)
# Leave unset to run local-only mode: scrape still runs, results skip Sheets.
# If set, grant the service account Editor access to the target Google Sheet.
GOOGLE_SERVICE_ACCOUNT_JSON=
